{
	"app_info":
	{
		"author":
		{
			"name": "Leonardo Pollini",
			"email": "leopollinik@gmail.com"
		},
		"version": "0.0.20",
		"autoupdate": false,
		"electron_package": "package.json",
		"app_name": "Webpage Accessor",
		"app_executable": "webpage_accessor"
	},

	"log":
	{
		"log_level": "WARNING",
		"log_file": "log.log",
		"actions":
		{
			"theese are just some examples": "I cannot use comments in json :(",
			"send_mail": {},
			"end_session": {}
		}
	},

	"configuration":
	{
		"keyboard_config":
		{
			"enabled": false,
			"whitelist": false,
			"blacklist": [],
			"extension": "keyboard-config"
		},
		"mouse_config": {},
		"touchscreen_config":
		{
			"enabled": true,
			"remap_to_pointeraction": true,
			"disable_physical_keyboard": false,
			"disable_virtual_keyboard": false,
			"one_button_at_a_time": true,
			"actions":
			{
				"enlarged_doubleclick":
				{
					"enabled": true,
					"doubleclick_sqr_radius": 1600,
					"doubleclick_max_delay": 500,
					"actions":
					{
						"lel": {"enabled": true, "extension": "touch-utils"}
					}
				}
			}
		},
		"other_actions":
		{
			"enabled": true,
			"actions":
			{
				"toolbar":
				{
					"enabled": false,
					"hidden": false,
					"extension": "toolbar"
				},
				"electron-api":
				{
					"enabled": true,
					"extension": "electronAPI"
				},
				"extra_extensions":
				{
					"enable_shortcuts": true,
					"hide_toolbar": true,
					"start_with_dev_tools": true,
					"extension": "window-events"
				},
				"startup_actions": {},
				"keys-checker":
				{
					"enabled": true,
					"extension": "keys-checker",
  					"custom_id": false,
					"structure_id": [1,2,3,4]
				},
				"autostart":
				{
					"desktop_filename": "webpage_accessor.desktop",
					"extension": "autostart"
				},
				"autoupdate":
				{
					"extension": "autoupdate",
					"enabled": true,
					"auto_download": false,
					"ask_update_on_start": false,
					"update_mode":
					{
						"mode": "long_press",
						"duration": 5
					}
				},
				"splashscreen":
				{
					"enabled": true,
					"extension": "splashscreen",
					"splash_timeout": 5,
					"splash_url":
					{
						"pathname": "google.com",
						"protocol": "https"
					}
				}
			}
		}
	},

	"default_data":
	{
		"fullscreen": true,
		"autostart": false,
		"autorestart": false,
		"autoreload": false,
		"only_one_webpage": true,
		"allow_navigation": true,
		"webpages":
		[
			{
				"pathname": "service.parchotels.it",
				"protocol": "https",
				"is_main_page": true,
				"require_private_window": true
			}
		]
	}
}