{
	"name": "webpage_accessor",
	"version": "0.0.59",
	"description": "Electron tests for independant desktop web app",
	"author": {
		"name": "Leonardo Pollini",
		"email": "leopollinik@gmail.com"
	},
	"main": "main.js",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"start": "electron --trace-warnings . -- create_config_link reload-configs",
		"start:autoupdate": "npx electronmon --trace-warnings .",
		"build": "electron-builder --publish=never",
		"publish": "electron-builder --publish=always"
	},
	"build": {
		"appId": "webpage_accessor",
		"productName": "webpage_accessor",
		"asar": false,
		"asarUnpack": [
			"extensions/*/**"
		],
		"linux": {
			"target": [
				"AppImage"
			],
			"executableArgs": [
				"--no-sandbox"
			],
			"category": "Utility",
			"icon": "build/icons/png"
		},
		"win": {
			"signAndEditExecutable": false,
			"target": [
				"portable"
			],
			"icon": "build/icons/win"
		},
		"publish": {
			"provider": "github",
			"owner": "leopollini",
			"repo": "webpage-accessor-interface"
		}
	},
	"keywords": [
		"electron",
		"test",
		"webapp"
	],
	"license": "ISC",
	"devDependencies": {
		"chalk": "^5.6.2",
		"dialog": "^0.3.1",
		"electron": "^37.4.0",
		"electron-builder": "^26.0.12"
	},
	"dependencies": {
		"autoupdate": "^1.0.1",
		"chalk": "^5.6.2",
		"create-desktop-shortcut": "^1.0.0",
		"create-desktop-shortcuts": "^1.11.1",
		"dialog": "^0.3.1",
		"electron-updater": "^6.6.2",
		"fs": "^0.0.1-security",
		"kleur": "^4.1.5",
		"node-machine-id": "^1.1.12"
	}
}
