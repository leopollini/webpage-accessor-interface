{
	"name": "webpage_accessor",
	"version": "1.0.0",
	"description": "Electron tests for independant desktop web app",
	"author": {
		"name": "Your Name",
		"email": "lel@sos.com"
	},
	"main": "main.js",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"start": "electron --trace-warnings . -- create_config_link",
		"start:autoupdate": "npx electronmon --trace-warnings .",
		"build": "electron-builder --publish=never"
	},
	"build": {
		"appId": "webpage_accessor",
		"productName": "webpage_accessor",
		"asar": false,
		"linux": {
			"target": [
				"deb"
			],
			"category": "Utility"
		}
	},
	"keywords": [
		"electron",
		"test",
		"webapp"
	],
	"license": "ISC",
	"devDependencies": {
		"electron": "^37.4.0",
		"electron-builder": "^26.0.12"
	},
	"dependencies": {
		"electron-updater": "^6.6.2",
		"fs": "^0.0.1-security",
		"kleur": "^4.1.5",
		"node-machine-id": "^1.1.12"
	}
}
