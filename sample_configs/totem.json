				},
				"mouse_config": {},
				"splashscreen": {
					"enabled": true,
					"extension": "splashscreen",
					"splash_timeout": 5,
					"splash_url": {
						"pathname": "w0.peakpx.com/wallpaper/407/567/HD-wallpaper-cat-black-background-cats-gatito-gato-gatos-kitties-kitty.jpg",
						"protocol": "https"
					}
				}
			}
		},
		"other_actions": {
			"enabled": true,
			"actions": {
				"webpage_filter": {
					"enabled": true,
					"hosts_whitelist": ["google", "parchotels"],
