					"enabled": true,
					"extension": "keys-checker",
					"custom_id": false,
					"structure_id": [1, 2, 3, 4]
				},
				"autostart": {
					"extension": "autostart"
				},
				"autoupdate": {
					"enabled": true,
					"extension": "autoupdate",
